# Required
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Optional — Email (weekly digest)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=radar@easestart.dev
RESEND_AUDIENCE_ID=aud_xxxxxxxx

# Dashboard
NEXT_PUBLIC_SITE_URL=https://easestart.github.io/repo-trend-radar

# Crawler config (tunable)
RADAR_DB_PATH=./data/radar.db
RADAR_EXPLORER_BATCH=5
RADAR_BREAKOUT_THRESHOLD=0.05
RADAR_STAR_CEILING=10000
RADAR_STAR_FLOOR=100
RADAR_SEEDLING_INTERVAL=3
